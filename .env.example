# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Database (host.docker.internal для Docker, localhost для запуска без Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@host.docker.internal:5432/passports

# OCR Provider
OCR_PROVIDER_MODEL=yandex

# Yandex Cloud OCR
YC_FOLDER_ID=your_folder_id_here
#
# Auth (выберите ОДИН вариант):
#
# Вариант 1 — API-ключ (рекомендуется, не истекает):
#   yc iam api-key create --service-account-name <имя> --scope yc.ai.vision.execute
YC_API_KEY=
#
# Вариант 2 — OAuth токен (авто-обновление IAM каждые 12ч):
#   Получить: https://oauth.yandex.ru/authorize?response_type=token&client_id=1a6990aa636648e9b2ef855fa7bec2fb
YC_OAUTH_TOKEN=
#
# Вариант 3 — IAM токен вручную (истекает через 12ч):
#   yc iam create-token
YC_IAM_TOKEN=
YC_OCR_ENDPOINT=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText
OCR_DOCUMENT_MODEL=passport
OCR_LANGUAGE_CODES=*

WEB_PORT=8080

# OpenRouter (vision LLM)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=google/gemini-flash-1.5
# Rate limit: max requests per minute (0 = unlimited)
OPENROUTER_RPM=0

# Output format templates
FORMAT_TYPE1={country}/{number}/{country}/{birth_date_long}/{gender}/{expiry_long}/{surname}/{name}
FORMAT_TYPE2=-{surname} {name} {birth_date_short}+{gender}/{country}/{doc_type} {number}/{expiry_short}

# OCR module priority (comma-separated, lower index = higher priority)
# Available: openrouter, yandex_ocr, rupasportread
# Docker Compose profiles set this automatically:
#   --profile light -> openrouter,yandex_ocr
#   --profile full  -> openrouter,yandex_ocr,rupasportread
OCR_MODULE_PRIORITY=openrouter,yandex_ocr

# OCR Limits
OCR_MAX_FILE_MB=10
OCR_MAX_MEGAPIXELS=20
OCR_RATE_LIMIT_RPS=1

# PDF Processing
PDF_RENDER_DPI=200

# Storage
TMP_DIR=./tmp
STORE_SOURCE_FILES=false

# Logging
LOG_LEVEL=INFO