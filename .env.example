# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/passports

# OCR Provider
OCR_PROVIDER_MODEL=yandex

# Yandex Cloud OCR
YC_FOLDER_ID=your_folder_id_here
YC_IAM_TOKEN=your_iam_token_here
YC_OCR_ENDPOINT=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText
OCR_DOCUMENT_MODEL=passport
OCR_LANGUAGE_CODES=*

# OpenRouter (vision LLM)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=google/gemini-flash-1.5

# Output format templates
FORMAT_TYPE1={country}/{number}/{country}/{birth_date_long}/{gender}/{expiry_long}/{surname}/{name}
FORMAT_TYPE2=-{surname} {name} {birth_date_short}+{gender}/{country}/{doc_type} {number}/{expiry_short}

# OCR module priority (comma-separated, lower index = higher priority)
# Available: openrouter, yandex_ocr, rupasportread
OCR_MODULE_PRIORITY=openrouter,yandex_ocr,rupasportread

# OCR Limits
OCR_MAX_FILE_MB=10
OCR_MAX_MEGAPIXELS=20
OCR_RATE_LIMIT_RPS=1

# PDF Processing
PDF_RENDER_DPI=200

# Storage
TMP_DIR=./tmp
STORE_SOURCE_FILES=false

# Logging
LOG_LEVEL=INFO