# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/passports

# OCR Provider
OCR_PROVIDER_MODEL=yandex

# Yandex Cloud OCR
YC_FOLDER_ID=your_folder_id
YC_AUTH_MODE=api_key
YC_IAM_TOKEN=
YC_API_KEY=your_api_key_here
YC_OCR_ENDPOINT=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText
OCR_DOCUMENT_MODEL=passport
OCR_LANGUAGE_CODES=*

# OCR Limits
OCR_MAX_FILE_MB=10
OCR_MAX_MEGAPIXELS=20
OCR_RATE_LIMIT_RPS=1

# PDF Processing
PDF_RENDER_DPI=200

# Storage
TMP_DIR=./tmp
STORE_SOURCE_FILES=false

# Logging
LOG_LEVEL=INFO
